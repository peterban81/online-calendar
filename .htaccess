DirectoryIndex index.php

<FilesMatch "^(config\.php|functions\.php|image-renderer\.php)$">
    Require all denied
</FilesMatch>

<IfModule mod_headers.c>
    <FilesMatch "\.(jpg|jpeg|png)$">
        Header set Cache-Control "no-cache, no-store, must-revalidate"
    </FilesMatch>
</IfModule>

Options -Indexes
